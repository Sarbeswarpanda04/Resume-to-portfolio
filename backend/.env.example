DATABASE_URL=mongodb://localhost:27017
DATABASE_NAME=resume_portfolio
SECRET_KEY=change-this-to-a-secure-secret-key-in-production
# Optional: Firebase Admin SDK service account JSON path
FIREBASE_CREDENTIALS_PATH=
PORTFOLIO_DOMAIN=yourapp.com

# Optional (enables AI parsing)
GEMINI_API_KEY=

# Optional (enables payments/billing)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
BILLING_ADMIN_SECRET=

# Dev-only: allow running backend without Firebase Admin token verification
DEV_AUTH_BYPASS=false
DEV_AUTH_USER_ID=demo-user
